{
  "cli": {
    "version": ">= 16.15.0"
  },
  "build": {
    "preview": {
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease",
        "env": {
          "EXPO_USE_DEV_CLIENT": "true"
        }
      }
    },
    "production": {
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease"
      }
    },
    "lightweight": {
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease",
        "env": {
          "EXPO_ANDROID_KEYSTORE_PASSWORD": "your-keystore-password",
          "EXPO_ANDROID_KEY_PASSWORD": "your-key-password"
        }
      }
    }
  }
}
